	"intro": "\uc624\ub974\ub9c9\uae38\uc744 \ub9cc\ub4e4\uc5b4\ub77c. \ud30c\ub3c4\ub97c \ud0c0\ub77c. \ud558\ub298\uc5d0 \ub2ff\uc544\ub77c.",
	"description": "\uc2a4\uce74\uc774 \ub9ac\uce58\ub294 \ubbf8\ub2c8\uba40\ub9ac\uc998 \ub514\uc790\uc778\uacfc \ub124\uc628 \ubd88\ube5b\uc73c\ub85c \uac00\ub4dd\ud55c \uc0ac\uc774\ubc84\ud391\ud06c \ub3c4\uc2dc\ub97c \ubc30\uacbd\uc73c\ub85c \ud3bc\uccd0\uc9c0\ub294 \ubb34\ud55c \ub4f1\ubc18 \uac8c\uc784\uc785\ub2c8\ub2e4. \uc5b4\ub450\ucef4\ucef4\ud55c \uc2ac\ub7fc\uac00\uc5d0\uc11c\ubd80\ud130 \ub4dc\ub113\uc740 \ud558\ub298\uae4c\uc9c0 \ubed7\uc5b4 \uc788\ub294 \ub3c4\uc2dc\ub97c \ubc30\uacbd\uc73c\ub85c, \ud50c\ub808\uc774\uc5b4\ub294 \uc791\uc740 \uc9c1\uc0ac\uac01\ud615 \uc601\uc6c5\uc774 \ub418\uc5b4 \uadf8 \uc5b4\ub290 \ub54c\ubcf4\ub2e4 \ub192\uc774 \uc62c\ub77c\uac00\ub294 \uac83\uc744 \ubaa9\ud45c\ub85c \ud569\ub2c8\ub2e4. \ubc1c\ud310 \uc0ac\uc774\ub97c \uc810\ud504\ud558\uace0, \ube60\ub974\uac8c \ubc18\uc751\ud558\uba70, \ubc1c\ubc11\uc758 \ub3c4\uc2dc\uac00 \uc5ed\ub3d9\uc801\uc73c\ub85c \uc6c0\uc9c1\uc774\ub294 \uac00\uc6b4\ub370 \ub04a\uc784\uc5c6\uc774 \uc704\ub85c \ub098\uc544\uac00\uc138\uc694.\n\n\ud558\uc9c0\ub9cc \uc2a4\uce74\uc774 \ub9ac\uce58\ub294 \ub2e8\uc21c\ud55c \uc810\ud504 \uc2e4\ub825\ub9cc\uc774 \uc804\ubd80\uac00 \uc544\ub2d9\ub2c8\ub2e4.\n\n\ub098\ub9cc\uc758 \uae38\uc744 \ub9cc\ub4e4\uc5b4\ub77c\n\n\ud575\uc2ec \uba54\ucee4\ub2c8\uc998\uc740 \uc5d0\ub108\uc9c0 \ud30c\ub3d9\uc744 \ubc1c\uc0ac\ud558\ub294 \uac83\uc785\ub2c8\ub2e4. \ub3c4\uc2dc \uc804\uccb4\uac00 \uc0b4\uc544\uc788\ub294 \ub4ef\ud55c \uc6c0\uc9c1\uc784\uc758 \ud30c\ub3d9\uc73c\ub85c \uac00\ub4dd \ucc28 \uc788\uc73c\uba70, \uc774 \ud30c\ub3d9\ub4e4\uc774 \ucda9\ub3cc\ud558\uba74 \uc0c8\ub85c\uc6b4 \ubc1c\ud310\uc774 \uc0dd\uc131\ub429\ub2c8\ub2e4.\n\n\ubaa8\ub4e0 \ubc1c\uc0ac\uac00 \uc911\uc694\ud558\uba70, \ucda9\ub3cc \ud558\ub098\ud558\ub098\uac00 \uacbd\ub85c\ub97c \ubc14\uafc0 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub2e8\uc21c\ud788 \ud0d1\uc744 \uc624\ub974\ub294 \uac83\uc774 \uc544\ub2c8\ub77c, \ud0d1\uc744 \uac74\uc124\ud574 \ub098\uac00\ub294 \uac83\uc785\ub2c8\ub2e4.\n\n\ud568\uaed8 \ub4f1\ubc18\ud558\uc138\uc694\n\n\uc194\ub85c \ud50c\ub808\uc774 \ub610\ub294 2\uc778 \ub85c\uceec \ud611\ub3d9 \ubaa8\ub4dc\ub85c \ud568\uaed8 \ud50c\ub808\uc774\ud558\uc138\uc694. \ucd94\ub77d \uc2dc \uc11c\ub85c\ub97c \ub3c4\uc640\uc8fc\uace0, \ud568\uaed8 \ubc1c\ud310\uc744 \ub9cc\ub4e4\uace0, \ud63c\uc790\uc11c\ub294 \uacb0\ucf54 \uc624\ub97c \uc218 \uc5c6\uc5c8\ub358 \ub192\uc774\uae4c\uc9c0 \uc62c\ub77c\uac00\uc138\uc694. \ud611\ub3d9\uc740 \uc0c8\ub85c\uc6b4 \ucd5c\uace0 \uae30\ub85d\uc744 \uc138\uc6b0\ub290\ub0d0, \uc544\ub2c8\uba74 \uc544\ucc14\ud55c \ucd94\ub77d\uc73c\ub85c \ub05d\ub098\ub290\ub0d0\ub97c \uacb0\uc815\uc9d3\ub294 \uc911\uc694\ud55c \uc694\uc18c\uac00 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ub192\uc774 \uc62c\ub77c\uac08\uc218\ub85d \ub354\uc6b1 \uac15\ud574\uc9c4\ub2e4\n\n\ub4f1\ubc18 \ubaa9\ud45c\ub97c \ub2ec\uc131\ud558\uc5ec \uc0c8\ub85c\uc6b4 \ud30c\uc6cc\uc5c5\uc744 \uc7a0\uae08 \ud574\uc81c\ud558\uc138\uc694. \ub354 \ub192\uc774 \uc810\ud504\ud558\uace0, \ub354 \ube60\ub974\uac8c \uc774\ub3d9\ud558\uace0, \ub4f1\ubc18 \uaddc\uce59\uc744 \ubc14\uafc0 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud30c\uc6cc\uc5c5\uc744 \ub9c8\uc2a4\ud130\ud558\uace0, \uc5f0\uc18d\uc73c\ub85c \uc2e4\ub825\uc744 \uac08\uace0\ub2e6\uc544 \ub354 \ub192\uc740 \uacf3\uacfc \ub354 \ub192\uc740 \uc810\uc218\ub97c \ud5a5\ud574 \ub098\uc544\uac00\uc138\uc694.\n\n\uc601\ud63c\uc774 \uae43\ub4e0 \ub124\uc628 \ub3c4\uc2dc\n\n\ub2e4\uc12f \uac00\uc9c0\uc758 \uac01\uae30 \ub2e4\ub978 \ub124\uc628 \ubc30\uacbd\uc744 \uc624\ub974\uba70 \ub3c4\uc2dc\uc758 \uc0c8\ub85c\uc6b4 \uba74\ubaa8\ub97c \uacbd\ud5d8\ud558\uc138\uc694. \uac70\uce5c \uac70\ub9ac\uc758 \uc2ac\ub7fc\uac00\ubd80\ud130 \ube5b\ub098\ub294 \uace0\uce35 \ube4c\ub529\uae4c\uc9c0 \ub2e4\ucc44\ub85c\uc6b4 \ud48d\uacbd\uc774 \ud3bc\uccd0\uc9d1\ub2c8\ub2e4. \uc561\uc158 \uc544\ub798\uc5d0\ub294 \uac10\ub3d9\uc801\uc778 \uc774\uc57c\uae30\uac00 \uc870\uc6a9\ud788 \ud3bc\uccd0\uc9c0\uba70, \ub4f1\ubc18\uc744 \ud1b5\ud574 \uadf8 \uac10\ub3d9\uc744 \uc804\ud569\ub2c8\ub2e4.",
