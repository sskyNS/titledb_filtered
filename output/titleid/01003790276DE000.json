	"intro": "\u300c\u5b8c\u74a7\u306a\u72af\u7f6a\u306e\u306f\u305a\u3060\u3063\u305f\u2014\u2014\u201c\u305f\u3063\u305f\u4e00\u3064\u306e\u30df\u30b9\u201d\u3092\u6d88\u3057\u304d\u308c\u308b\u304b\uff1f\u300d",
	"description": "\u300c\u672a\u89e3\u6c7a\u30df\u30b9\u30c6\u30ea\u30fc \u30fc\u672c\u683c\u8b0e\u89e3\u304d\u63a8\u7406\u30b5\u30b9\u30da\u30f3\u30b9\u30b2\u30fc\u30e0\u30fc\u300d\u306f\u3001\n\u4e8b\u4ef6\u73fe\u5834\u306e\u30a4\u30e9\u30b9\u30c8\u306b\u6f5c\u3080\u201c\u72af\u4eba\u306e\u5931\u6557\u201d\u3092\u898b\u3064\u3051\u3001\u8a3c\u62e0\u3092\u96a0\u6ec5\u3057\u3066\u3044\u304f\u63a8\u7406\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u3042\u306a\u305f\u306f\u72af\u4eba\u306e\u5354\u529b\u8005\u3002\n\u72af\u884c\u306f\u5b8c\u74a7\u3060\u3063\u305f\u2014\u2014\u306f\u305a\u306a\u306e\u306b\u3001\n\u305f\u3063\u305f\u4e00\u3064\u3001\u81f4\u547d\u7684\u306a\u30df\u30b9\u3092\u6b8b\u3057\u3066\u3057\u307e\u3063\u305f\u3002\n\n\u73fe\u5834\u306b\u6b8b\u3055\u308c\u305f\u9055\u548c\u611f\u3001\u30ba\u30ec\u3001\u4e0d\u81ea\u7136\u306a\u75d5\u8de1\u2026\u3002\n\u554f\u984c\u6587\u3092\u30d2\u30f3\u30c8\u306b\u3001\u201c\u30d0\u30ec\u308b\u8981\u7d20\u201d\u3092\u63a2\u3057\u51fa\u3057\u3001\u30bf\u30c3\u30d7\u3057\u3066\u6d88\u3057\u53bb\u308c\uff01\n\n\u8b66\u5bdf\u304c\u6765\u308b\u524d\u306b\u3059\u3079\u3066\u3092\u51e6\u7406\u3067\u304d\u308b\u304b\uff1f\n\u305d\u308c\u3068\u3082\u3001\u3042\u306a\u305f\u306e\u7f6a\u306f\u66b4\u304b\u308c\u3066\u3057\u307e\u3046\u306e\u304b\u2014\u2014\u3002\n\n\u300c\u3053\u3053\u304c\u602a\u3057\u3044\u2026\u3044\u3084\u9055\u3046\uff1f\u300d\n\u300c\u3048\u3001\u305d\u308c\u304c\u8a3c\u62e0\u306b\u306a\u308b\u306e\uff01\uff1f\u300d\n\n\u30d7\u30ec\u30a4\u3059\u308b\u307b\u3069\u306b\u89b3\u5bdf\u529b\u3068\u63a8\u7406\u529b\u304c\u8a66\u3055\u308c\u308b\u3001\n\u30b9\u30ea\u30eb\u6e80\u70b9\u306e\u201c\u72af\u4eba\u8996\u70b9\u201d\u30df\u30b9\u30c6\u30ea\u30fc\u4f53\u9a13\u3002\n\n\u76f4\u611f\u3067\u904a\u3079\u308b\u30ab\u30b8\u30e5\u30a2\u30eb\u3055\u3068\u3001\n\u3058\u308f\u3058\u308f\u8ffd\u3044\u8a70\u3081\u3089\u308c\u308b\u5fc3\u7406\u7684\u7dca\u5f35\u611f\u3092\u4e21\u7acb\u3057\u305f\u4e00\u4f5c\u3067\u3059\u3002\n\n\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\nTT\u3067\u306f\u52d5\u753b\u914d\u4fe1\u8005\u69d8\u306e\u30b2\u30fc\u30e0\u5b9f\u6cc1\u3092\u5fdc\u63f4\u3057\u3066\u304a\u308a\u307e\u3059\u3002\n\u500b\u4eba\u30fb\u6cd5\u4eba\u3092\u554f\u308f\u305a\u3001\u30b2\u30fc\u30e0\u5b9f\u6cc1\u306b\u3064\u3044\u3066TT\u306b\u8a31\u53ef\u3092\u53d6\u308b\u5fc5\u8981\u306f\u3042\u308a\u307e\u305b\u3093\u3002",
