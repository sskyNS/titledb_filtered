	"intro": "\u504f\u5dee\u502455\u30ec\u30d9\u30eb\u306b\u6311\u6226\uff01\n4\u629e\u3067\u57fa\u790e\u529b\u3092\u56fa\u3081\u308b\u3001\u4e2d\u5b66\u53d7\u9a13\u5bfe\u7b56\u30af\u30a4\u30ba\uff01",
	"description": "\u300c\u4e2d\u5b66\u53d7\u9a13\u306e\u6559\u79d1\u66f8\u30fc\u53d7\u9a13\u306b\u5411\u3051\u3066\u57fa\u790e\u304c\u8eab\u306b\u4ed8\u304f\u5b66\u7fd2\u52c9\u5f37\u30af\u30a4\u30ba\u30fc\u300d\u306f\u3001\u504f\u5dee\u502455\u7a0b\u5ea6\u306e\u4e2d\u5b66\u53d7\u9a13\u5165\u8a66\u30ec\u30d9\u30eb\u306e\u554f\u984c\u306b\u6311\u6226\u3067\u304d\u308b4\u629e\u30af\u30a4\u30ba\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u56fd\u8a9e\u30fb\u7b97\u6570\u30fb\u7406\u79d1\u30fb\u793e\u4f1a\u306a\u3069\u3001\u5b9f\u969b\u306e\u5165\u8a66\u3092\u610f\u8b58\u3057\u305f\u554f\u984c\u3092\u53ce\u9332\u3002\n\u57fa\u790e\u3092\u3057\u3063\u304b\u308a\u7406\u89e3\u3057\u3066\u3044\u308b\u304b\u3092\u78ba\u8a8d\u3057\u306a\u304c\u3089\u3001\u30c6\u30f3\u30dd\u3088\u304f\u89e3\u304d\u9032\u3081\u3089\u308c\u307e\u3059\u3002\n\n\u300c\u306a\u3093\u3068\u306a\u304f\u89e3\u3051\u308b\u300d\u304b\u3089\u300c\u78ba\u5b9f\u306b\u5f97\u70b9\u3067\u304d\u308b\u300d\u3078\u3002\n\u672c\u756a\u3067\u5dee\u304c\u3064\u304f\u57fa\u790e\u529b\u3092\u3001\u30b2\u30fc\u30e0\u611f\u899a\u3067\u8eab\u306b\u3064\u3051\u307e\u3057\u3087\u3046\u3002\n\n\u901a\u5b66\u524d\u306e\u30b9\u30ad\u30de\u6642\u9593\u3084\u3001\u6bce\u65e5\u306e\u6f14\u7fd2\u306e\u5fa9\u7fd2\u306b\u3082\u6700\u9069\u3002\n\u30dc\u30bf\u30f3\u64cd\u4f5c\u3067\u30b5\u30af\u30b5\u30af\u56de\u7b54\u3067\u304d\u308b\u306e\u3067\u3001\u7e70\u308a\u8fd4\u3057\u5b66\u7fd2\u306b\u3082\u3074\u3063\u305f\u308a\u3067\u3059\u3002\n\n\u4e00\u4eba\u3067\u306e\u5b9f\u529b\u30c1\u30a7\u30c3\u30af\u306f\u3082\u3061\u308d\u3093\u3001\n\u89aa\u5b50\u3067\u6311\u6226\u3057\u3066\u5b9f\u529b\u3092\u78ba\u8a8d\u3059\u308b\u5b66\u7fd2\u30c4\u30fc\u30eb\u3068\u3057\u3066\u3082\u6d3b\u7528\u3067\u304d\u307e\u3059\u3002\n\n\u203b\u30dc\u30bf\u30f3\u64cd\u4f5c\u306b\u3082\u5bfe\u5fdc\u3057\u3066\u3044\u308b\u306e\u3067\u3001\u30c6\u30fc\u30d6\u30eb\u30e2\u30fc\u30c9\u3001TV\u30e2\u30fc\u30c9\u3067\u3082\u697d\u3057\u3081\u307e\u3059\u3002\n\n\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\nMASK\u3067\u306f\u52d5\u753b\u914d\u4fe1\u8005\u69d8\u306e\u30b2\u30fc\u30e0\u5b9f\u6cc1\u3092\u5fdc\u63f4\u3057\u3066\u304a\u308a\u307e\u3059\u3002\n\u500b\u4eba\u30fb\u6cd5\u4eba\u3092\u554f\u308f\u305a\u3001\u30b2\u30fc\u30e0\u5b9f\u6cc1\u306b\u3064\u3044\u3066MASK\u306b\u8a31\u53ef\u3092\u53d6\u308b\u5fc5\u8981\u306f\u3042\u308a\u307e\u305b\u3093\u3002",
