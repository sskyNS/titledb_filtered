	"intro": "\u300c\u305d\u306e\u5bb6\u3001\u4f55\u304b\u304c\u304a\u304b\u3057\u3044\u3002\u300d4\u629e\u3067\u66b4\u304f\u30c9\u30c3\u30c8\u63a8\u7406\u30df\u30b9\u30c6\u30ea\u30fc",
	"description": "\u300c\u30c8\u30ea\u30c3\u30af\u30eb\u30fc\u30e0\u300d\u306f\u3001\u30c9\u30c3\u30c8\u7d75\u3067\u63cf\u304b\u308c\u305f\u5bb6\u306e\u4e2d\u3092\u821e\u53f0\u306b\u3001\n\u9055\u548c\u611f\u3084\u624b\u304c\u304b\u308a\u3092\u898b\u3064\u3051\u306a\u304c\u3089\u4e8b\u4ef6\u306e\u771f\u76f8\u306b\u8feb\u308b4\u629e\u63a8\u7406\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u3001\u554f\u984c\u6587\u3068\u30a4\u30e9\u30b9\u30c8\u3092\u3082\u3068\u306b\u72b6\u6cc1\u3092\u8aad\u307f\u89e3\u304d\u3001\n4\u3064\u306e\u9078\u629e\u80a2\u304b\u3089\u6b63\u89e3\u3092\u9078\u3093\u3067\u7269\u8a9e\u3092\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002\n\n1\u3064\u306e\u4e8b\u4ef6\u306f\u51685\u554f\u3067\u69cb\u6210\u3055\u308c\u3066\u304a\u308a\u3001\n\u77ed\u7de8\u306a\u304c\u3089\u3082\u201c\u6c17\u3065\u304d\u201d\u3068\u201c\u3072\u3089\u3081\u304d\u201d\u304c\u8a66\u3055\u308c\u308b\u6fc3\u5bc6\u306a\u30b9\u30c8\u30fc\u30ea\u30fc\u4f53\u9a13\u304c\u697d\u3057\u3081\u307e\u3059\u3002\n\n\u300c\u3053\u306e\u90e8\u5c4b\u3001\u3069\u3053\u304b\u5909\u3058\u3083\u306a\u3044\uff1f\u300d\n\u300c\u72af\u4eba\u306f\u307e\u3060\u90e8\u5c4b\u306e\u4e2d\u306b\u2026\uff01\u300d\n\n\u65e5\u5e38\u306b\u6f5c\u3080\u5c0f\u3055\u306a\u9055\u548c\u611f\u304b\u3089\u3001\u601d\u308f\u306c\u771f\u5b9f\u3078\u2015\u2015\n\u3042\u306a\u305f\u306e\u89b3\u5bdf\u529b\u3068\u63a8\u7406\u529b\u3067\u3001\u3059\u3079\u3066\u306e\u8b0e\u3092\u89e3\u304d\u660e\u304b\u3057\u307e\u3057\u3087\u3046\u3002\n\n\u76f4\u611f\u3067\u904a\u3079\u308b\u624b\u8efd\u3055\u3068\u3001\u89e3\u3051\u305f\u3068\u304d\u306e\u723d\u5feb\u611f\u304c\u30af\u30bb\u306b\u306a\u308b\u3001\n\u3072\u3089\u3081\u304d\u578b\u30df\u30b9\u30c6\u30ea\u30fc\u30d1\u30ba\u30eb\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\nTT\u3067\u306f\u52d5\u753b\u914d\u4fe1\u8005\u69d8\u306e\u30b2\u30fc\u30e0\u5b9f\u6cc1\u3092\u5fdc\u63f4\u3057\u3066\u304a\u308a\u307e\u3059\u3002\n\u500b\u4eba\u30fb\u6cd5\u4eba\u3092\u554f\u308f\u305a\u3001\u30b2\u30fc\u30e0\u5b9f\u6cc1\u306b\u3064\u3044\u3066TT\u306b\u8a31\u53ef\u3092\u53d6\u308b\u5fc5\u8981\u306f\u3042\u308a\u307e\u305b\u3093\u3002",
