	"intro": "\u5206\u8eab\u306e\u8853\u3092\u6d3b\u7528\u3057\u3001\u751f\u547d\u306e\u77f3\u3092\u53d6\u308a\u623b\u305b\uff01",
	"description": "\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u90aa\u60aa\u306a\u50e7\u4fb6\u30fb\u30c9\u30af\u304b\u3089\u6751\u3092\u5b88\u308b\u305f\u3081\u3001\u9752\u5e74\u306e\u5fcd\u8005\u30fb\u30d2\u30b3\u3068\u5f7c\u306e\u5206\u8eab\u3092\u64cd\u308a\u3001\u30d1\u30ba\u30eb\u3092\u653b\u7565\u3057\u3001\u6575\u3092\u5012\u3057\u3066\u3044\u304d\u307e\u3059\u3002\n\n\u9060\u304f\u4eba\u91cc\u96e2\u308c\u305f\u7af9\u306e\u6751\u306b\u306f\u3001\u5f37\u3055\u3068\u8abf\u548c\u306e\u6e90\u3067\u3042\u308b\u751f\u547d\u306e\u77f3\u304c\u3042\u3063\u305f\u3002\u90aa\u60aa\u306a\u50e7\u4fb6\u30fb\u30c9\u30af\u306b\u3088\u308a\u305d\u306e\u77f3\u304c\u76d7\u307e\u308c\u305f\u6642\u3001\u3068\u3042\u308b\u82e5\u3044\u5fcd\u8005\u3001\u30d2\u30b3\u304c\u305d\u306e\u77f3\u3092\u53d6\u308a\u623b\u3057\u3001\u518d\u3073\u6751\u306b\u5e73\u548c\u3092\u3082\u305f\u3089\u3059\u305f\u3081\u306b\u7acb\u3061\u4e0a\u304c\u308b\u3002\n\n\u300e\u30cb\u30f3\u30b8\u30e3\u30e9\u30fb\u30a8\u30b3\u30fc\u300f\u30b7\u30e3\u30c9\u30a6 \u30af\u30ed\u30fc\u30f3\uff08\u5206\u8eab\uff09\u3092\u4f5c\u6210\u3057\u3066\u5236\u5fa1\u3059\u308b\u3068\u3044\u3046\u72ec\u81ea\u306e\u30e1\u30ab\u30cb\u30ba\u30e0\u306b\u57fa\u3065\u3044\u3066\u69cb\u7bc9\u3055\u308c\u305f 2D \u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0 \u30b2\u30fc\u30e0\u3067\u3059\u3002\u64cd\u4f5c\u306f\u305f\u3060\u30b8\u30e3\u30f3\u30d7\u3057\u305f\u308a\u6226\u3063\u305f\u308a\u3059\u308b\u3060\u3051\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u3042\u3089\u3086\u308b\u52d5\u304d\u306b\u6226\u7565\u304c\u5fc5\u8981\u3067\u3059\u3002\u5206\u8eab\u3092\u3046\u307e\u304f\u4f7f\u3063\u3066\u3001\u30b9\u30a4\u30c3\u30c1\u3092\u62bc\u3057\u305f\u308a\u3001\u30ec\u30d0\u30fc\u3092\u63e1\u3063\u305f\u308a\u3001\u6575\u306e\u6ce8\u610f\u3092\u305d\u3089\u3057\u305f\u308a\u3059\u308b\u3053\u3068\u3067\u3001\u65b0\u305f\u306a\u653b\u7565\u304c\u898b\u3064\u304b\u308a\u307e\u3059\u3002\n\n\u30d2\u30b3\u306f\u81ea\u8eab\u306e\u9b42\u3092\u5206\u8eab\u306b\u79fb\u884c\u3067\u304d\u308b\u80fd\u529b\u3092\u6301\u3063\u3066\u304a\u308a\u3001\u8907\u6570\u306e\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u3092\u540c\u6642\u306b\u64cd\u4f5c\u3057\u3001\u5206\u8eab\u304c\u30ab\u30ae\u3068\u306a\u308b\u8907\u96d1\u306a\u30d1\u30ba\u30eb\u3092\u89e3\u304f\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u5206\u8eab\u3092\u4f7f\u3063\u3066\u5854\u3092\u5efa\u3066\u305f\u308a\u3001\u96a0\u308c\u305f\u7a7a\u9593\u306b\u5230\u9054\u3057\u305f\u308a\u3001\u5371\u967a\u306a\u7f60\u3092\u56de\u907f\u3057\u305f\u308a\u3057\u3088\u3046\u3002\n\n\n\u6226\u3044\u306f\u7cbe\u5bc6\u3055\u3068\u6226\u8853\u304c\u878d\u5408\u3057\u305f\u3082\u306e\u3067\u3001\u624b\u88cf\u5263\u3092\u6295\u3052\u3001\u63a5\u8fd1\u6226\u3067\u653b\u6483\u3057\u3001\u5fcd\u8005\u306e\u6280\u3092\u7fd2\u5f97\u3057\u3066\u6575\u3092\u5012\u3057\u307e\u3059\u3002\u5404\u30ec\u30d9\u30eb\u306f\u30b9\u30ad\u30eb\u3068\u6226\u7565\u306e\u8a66\u7df4\u3068\u306a\u308a\u3001\u305d\u308c\u306f\u58ee\u5927\u306a\u30dc\u30b9\u3068\u306e\u6226\u306b\u7e4b\u304c\u308a\u307e\u3059\u3002\u6700\u7d42\u6c7a\u6226\u3067\u306f\u3001\u30c9\u30af\u672c\u4eba\u3068\u306e\u5bfe\u6c7a\u304c\u5f85\u3063\u3066\u3044\u307e\u3059\u3002\n\n\u5f71\u306e\u529b\u3092\u89e3\u653e\u3057\u3001\u77e5\u6075\u3068\u53cd\u5c04\u795e\u7d4c\u3092\u6d3b\u7528\u3057\u3001\u751f\u547d\u306e\u77f3\u3092\u53d6\u308a\u623b\u3057\u3001\u6751\u3092\u6551\u304a\u3046\uff01\n\n\n\u7279\u5fb4\n* \u9b42\u3092\u79fb\u884c\u3067\u304d\u308b\u8981\u7d20\u3092\u4f7f\u3044\u5206\u8eab\u3092\u751f\u307f\u51fa\u3057\u30b3\u30f3\u30c8\u30ed\u30fc\u30eb\n* \u30d1\u30ba\u30eb\u3001\u305d\u3057\u3066\u30c6\u30f3\u30dd\u306e\u901f\u3044\u6226\u95d8\u304c\u878d\u5408\u3057\u305f\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\n* \u5f79\u7acb\u3064\u4ef2\u9593\u305f\u3061: \u8ce2\u3044\u72ac\u30fb\u30dd\u30c1\u3084\u30b9\u30ad\u30eb\u3092\u5f37\u5316\u3057\u3066\u304f\u308c\u308b\u30d5\u30ed\u30ac\u30b9\n* \u30c9\u30af\