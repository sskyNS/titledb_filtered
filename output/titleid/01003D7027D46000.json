	"intro": "\u6df7\u6c8c\u3068\u3057\u305f\u4e16\u754c\u306e\u4e2d\u3067\u3001\u3042\u306a\u305f\u306e\u30d2\u30e5\u30c3\u30b2\u306a\u90e8\u5c4b\u304c\u5fc3\u306e\u907f\u96e3\u6240\u306b\u306a\u308b\u3002",
	"description": "\u672c\u4f5c\u306f\u65e5\u672c\u8a9e\u306b\u5bfe\u5fdc\u3057\u3066\u304a\u308a\u307e\u305b\u3093\u3002\n\n\u3053\u306e\u5fc3\u5730\u3088\u304f\u300c\u30d2\u30e5\u30c3\u30b2\u300d\u306b\u7740\u60f3\u3092\u5f97\u305f\u30db\u30fc\u30e0\u30b7\u30df\u30e5\u30ec\u30fc\u30bf\u30fc\u3067\u3001\u3042\u306a\u305f\u306e\u7406\u60f3\u306e\u66ae\u3089\u3057\u3092 unpack \u3057\u3088\u3046\u3002\n\u5275\u9020\u6027\u3001\u5feb\u9069\u3055\u3001\u305d\u3057\u3066\u81ea\u5df1\u8868\u73fe\u306b\u7126\u70b9\u3092\u5f53\u3066\u305f\u30ea\u30e9\u30c3\u30af\u30b9\u3067\u7791\u60f3\u7684\u306a\u4f53\u9a13\u306e\u4e2d\u3067\u3001\u5922\u306e\u30a2\u30d1\u30fc\u30c8\u3092\u30c7\u30b6\u30a4\u30f3\u3057\u3088\u3046\u3002\n\n\u4e8c\u5c64\u69cb\u9020\u306e\u30e6\u30cb\u30fc\u30af\u306a\u5bb6\u3092\u4f5c\u308a\u3001\u6c17\u5206\u306b\u5408\u308f\u305b\u3066\u5404\u90e8\u5c4b\u3092\u98fe\u308a\u3001\u5ead\u3084\u5c4b\u5916\u30b9\u30da\u30fc\u30b9\u307e\u3067\u30c7\u30b6\u30a4\u30f3\u53ef\u80fd\u3002\u5bb6\u5177\u3092\u914d\u7f6e\u3057\u3001\u8272\u306e\u7d44\u307f\u5408\u308f\u305b\u3092\u8a66\u3057\u3001\u5149\u3084\u5929\u5019\u3092\u5909\u3048\u3066\u7a93\u306e\u5916\u306e\u96f0\u56f2\u6c17\u3092\u30ab\u30b9\u30bf\u30de\u30a4\u30ba\u3057\u3088\u3046\u3002\n\n\u30df\u30cb\u30de\u30eb\u306a\u30ed\u30d5\u30c8\u3001\u67d4\u3089\u304b\u306a\u5317\u6b27\u30b9\u30bf\u30a4\u30eb\u306e\u5bdd\u5ba4\u3001\u3042\u308b\u3044\u306f\u4e0d\u601d\u8b70\u306a\u9b54\u6cd5\u4f7f\u3044\u306e\u5730\u4e0b\u5ba4\u2015\u2015\u4f55\u3092\u4f5c\u308b\u306b\u3057\u3066\u3082\u3001\u3053\u3053\u306f\u3042\u306a\u305f\u304c\u81ea\u7531\u306b\u5f62\u3065\u304f\u308b\u7a7a\u9593\u3002\n\n\u7279\u5fb4:\n\u2022 \u300c\u30d2\u30e5\u30c3\u30b2\u300d\u30e9\u30a4\u30d5\u30b9\u30bf\u30a4\u30eb\u306b\u30a4\u30f3\u30b9\u30d1\u30a4\u30a2\u3055\u308c\u305f\u7a4f\u3084\u304b\u3067\u5fc3\u5730\u3088\u3044\u30b7\u30df\u30e5\u30ec\u30fc\u30bf\u30fc\n\u2022 \u76f4\u611f\u7684\u306a\u64cd\u4f5c\u3067\u5bb6\u5177\u3092\u958b\u5c01\u3057\u3066\u914d\u7f6e\n\u2022 \u58c1\u3001\u5e8a\u3001\u7167\u660e\u3001\u7a93\u306e\u666f\u8272\u3092\u30ab\u30b9\u30bf\u30de\u30a4\u30ba\n\u2022 \u5ead\u3092\u542b\u3080\u5c4b\u5185\u5916\u306e\u30b9\u30da\u30fc\u30b9\u3092\u30c7\u30b6\u30a4\u30f3\n\u2022 \u5782\u76f4\u30ec\u30a4\u30a2\u30a6\u30c8\u3067\u591a\u5c64\u69cb\u9020\u306e\u5bb6\u3092\u4f5c\u6210\n\u2022 \u500b\u6027\u7684\u306a\u30c6\u30fc\u30de\u306e\u30ea\u30e9\u30c3\u30af\u30b9\u3067\u304d\u308b\u30c7\u30b6\u30a4\u30f3\u30af\u30a8\u30b9\u30c8\u3092\u5b8c\u4e86\n\u2022 \u9759\u304b\u3067\u30b9\u30c8\u30ec\u30b9\u306e\u306a\u3044\u74b0\u5883\u3092\u697d\u3057\u3081\u308b",
