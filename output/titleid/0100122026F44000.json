	"intro": "\u30dc\u30fc\u30c9\u30b2\u30fc\u30e0\u00d7\u30ab\u30fc\u30c9\u30b2\u30fc\u30e0\u306e\u91d1\u5b57\u5854\u3001\u3053\u3053\u306b\u5fa9\u6d3b\u3002",
	"description": "\u4e16\u754c\u4e2d\u306e\u30d7\u30ec\u30a4\u30e4\u30fc\u305f\u3061\u3092\u71b1\u72c2\u3055\u305b\u305f\u300e\u30ab\u30eb\u30c9\u30bb\u30d7\u30c8\u300f\u30b7\u30ea\u30fc\u30ba\u3002\u305d\u306e\u7b2c1\u4f5c\u76ee\u304c\u3001\u4fbf\u5229\u306a\u65b0\u6a5f\u80fd\u3092\u642d\u8f09\u3057\u3066\u5fa9\u523b\u3002\n300\u7a2e\u985e\u4ee5\u4e0a\u306e\u30ab\u30fc\u30c9\u304b\u3089\u30c7\u30c3\u30ad\u3092\u69cb\u7bc9\u3002\u30bb\u30d7\u30bf\u30fc\u305f\u3061\u306e\u6226\u3044\u304c\u518d\u3073\u5e55\u3092\u958b\u3051\u307e\u3059\u3002\n\n\u25c6\u795e\u3005\u304c\u907a\u3057\u305f\u201c\u66f8\u201d\u304c\u3001\u4e16\u754c\u3092\u52d5\u304b\u3059\u3002\n\u304b\u3064\u3066\u4e3b\u795e\u30ab\u30eb\u30c9\u30e9\u3068\u4e2d\u7acb\u795e\u30d0\u30eb\u30c6\u30a2\u30b9\u304c\u6226\u3063\u305f\u5927\u9678\u30d0\u30d6\u30e9\u30b7\u30e5\u30ab\u3067\u306f\u3001\u30ab\u30eb\u30c9\u30e9\u306e\u6700\u5f8c\u306e\u5275\u9020\u7269\u3067\u3042\u308b\u4eba\u9593\u305f\u3061\u304c\u7e41\u6804\u3057\u3066\u3044\u305f\u3002\u3057\u304b\u3057\u5404\u5730\u3067\u898b\u3064\u304b\u3063\u305f\u77f3\u677f\u304c\u3001\u5275\u9020\u3068\u7834\u58ca\u306e\u66f8\u300c\u30ab\u30eb\u30c9\u30bb\u30d7\u30c8\u300d\u306e\u7834\u7247\u3060\u3068\u5224\u660e\u3057\u305f\u3053\u3068\u3067\u3001\u4e16\u754c\u306f\u6df7\u4e71\u306b\u9665\u308b\u3002\u300c\u30ab\u30eb\u30c9\u30bb\u30d7\u30c8\u3092\u7d71\u3079\u308b\u8005\u306f\u7121\u9650\u306e\u529b\u3092\u5f97\u308b\u300d\u3068\u3044\u3046\u795e\u8a71\u306e\u8a00\u8449\u306b\u5c0e\u304b\u308c\u3001\u30bb\u30d7\u30bf\u30fc\u305f\u3061\u306f\u7834\u7247\u3092\u5de1\u3063\u3066\u4e89\u3044\u3092\u59cb\u3081\u305f\u3002\n\u6226\u798d\u304c\u5e83\u304c\u308b\u4e2d\u3001\u3084\u304c\u3066\u4e00\u4eba\u306e\u82e5\u8005\u304c\u7acb\u3061\u4e0a\u304c\u308a\u3001\u9577\u3044\u65c5\u3078\u3068\u8e0f\u307f\u51fa\u3059\u3002\n\n\u25c6\u9818\u5730\u3092\u596a\u3044\u5408\u3046\u30bb\u30d7\u30bf\u30fc\u305f\u3061\u306e\u653b\u9632\u6226\n\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u30ab\u30fc\u30c9\u3092\u64cd\u308b\u300c\u30bb\u30d7\u30bf\u30fc\u300d\u3068\u306a\u308a\u3001\u81ea\u3089\u69cb\u7bc9\u3057\u305f50\u679a\u306e\u30d6\u30c3\u30af\uff08\u30c7\u30c3\u30ad\uff09\u3092\u624b\u306b\u6226\u3044\u306b\u81e8\u307f\u307e\u3059\u3002\n\u30c0\u30a4\u30b9\u306e\u5c0e\u304d\u306b\u3088\u3063\u3066\u30de\u30c3\u30d7\u3092\u79fb\u52d5\u3057\u3001\u6b62\u307e\u3063\u305f\u571f\u5730\u3067\u30ab\u30fc\u30c9\u3092\u4f7f\u3063\u3066\u30af\u30ea\u30fc\u30c1\u30e3\u30fc\u3092\u53ec\u559a\u3002\u30af\u30ea\u30fc\u30c1\u30e3\u30fc\u3092\u7f6e\u3044\u305f\u571f\u5730\u306f\u81ea\u5206\u306e\u9818\u5730\u306b\u306a\u308a\u307e\u3059\u3002\u30b9\u30da\u30eb\u30ab\u30fc\u30c9\u3092\u4f7f\u7528\u3059\u308c\u3070\u3001\u30c0\u30a4\u30b9\u306e\u76ee\u306e\u64cd\u4f5c\u3084\u30af\u30ea\u30fc\u30c1\u30e3\u30fc\u306e\u652f\u63f4\u3001\u30e9\u30a4\u30d0\u30eb\u306e\u59a8\u5bb3\u3082\u53ef\u80fd\u3067\u3059\u3002\u9b54\u529b\u3092\u76ee\u6a19\u6570\u5024\u307e\u3067\u96c6\u3081\u3001\u30b9\u30bf\u30fc\u30c8\u5730\u70b9\u3067\u3042\u308b\u57ce\u306b\u623b\u3063\u305f\u30bb\u30d7\u30bf\u30fc\u304c\u52dd\u8005\u3068\u306a\u308a\u307e\u3059\u3002\n\u8a66\u5408\u7d42\u4e86\u5f8c\u306b\u306f\u9806\u4f4d\u306b\u5fdc\u3058\u305f\u679a\u6570\u306e\u30ab\u30fc\u30c9\u304c\u30e9\u30f3\u30c0\u30e0\u3067\u624b\u306b\u5165\u308a\u307e\u3059\u3002\u65b0\u305f\u306a\u30ab\u30fc\u30c9\u3092\u30d6\u30c3\u30af\u306b\u7de8\u6210\u3057\u3001\u6b21\u306a\u308b\u6226\u3044\u306b\u5411\u3051\u3066\u6226\u8853\u3092\u78e8\u304d\u4e0a\u3052\u307e\u3057\u3087\u3046\u3002\n\n\u25c6180\u7a2e\u306e\u30af\u30ea\u30fc\u30c1\u30e3\u30fc\u304c\u7e70\u308a\u5e83\u3052\u308b\u767d\u71b1\u306e\u30d0\u30c8\u30eb\n\u4ed6\u8005\u306e\u9818\u5730\u306b\u6b62\u307e\u3063\u305f\u6642\u306f\u3001\u901a\u884c\u6599\u3068\u3057\u3066\u9b54\u529b\u3092\u652f\u6255\u3046\u3053\u3068\u306b\u306a\u308a\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u30af\u30ea\u30fc\u30c1\u30e3\u30fc\u3092\u53ec\u559a\u3057\u3066\u6226\u95d8\u306b\u52dd\u5229\u3059\u308b\u3053\u3068\u3067\u3001\u9818\u5730\u3092\u81ea\u5206\u306e\u3082\u306e\u306b\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\u30d0\u30c8\u30eb\u3067\u306f\u3001\u30af\u30ea\u30fc\u30c1\u30e3\u30fc\u306e\u30b9\u30c6\u30fc\u30bf\u30b9\u3068\u7279\u6b8a\u80fd\u529b\u306b\u52a0\u3048\u3066\u3001\u30a2\u30a4\u30c6\u30e0\u30ab\u30fc\u30c9\u306e\u52b9\u679c\u3001\u571f\u5730\u3084\u5473\u65b9\u306e\u30b5\u30dd\u30fc\u30c8\u52b9\u679c\u306a\u3069\u3082\u52dd\u6557\u3092\u5206\u3051\u308b\u6c7a\u3081\u624b\u3068\u306a\u308a\u307e\u3059\u3002\n\u9818\u5730\u3092\u596a\u3044\u53d6\u308a\u3001\u3055\u3089\u306b\u9b54\u529b\u3092\u9ad8\u3081\u3066\u30b2\u30fc\u30e0\u3092\u6709\u5229\u306b\u9032\u3081\u3066\u3044\u304d\u307e\u3057\u3087\u3046\u3002\n\n\u25c6\u5feb\u9069\u306a\u30d7\u30ec\u30a4\u3092\u652f\u3048\u308b\u65b0\u6a5f\u80fd\u3092\u642d\u8f09\n\u30ea\u30ef\u30a4\u30f3\u30c9\uff1a\u30de\u30c3\u30d7\u4e2d\u306e\u30c1\u30a7\u30c3\u30af\u30dd\u30a4\u30f3\u30c8\u3067\u3042\u308b\u300c\u7826\u300d\u3084\u300c\u57ce\u300d\u3092\u901a\u904e\u3057\u305f\u30bf\u30a4\u30df\u30f3\u30b0\u307e\u3067\u30b2\u30fc\u30e0\u3092\u5dfb\u304d\u623b\u3059\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\u30af\u30a4\u30c3\u30af\u30bb\u30fc\u30d6/\u30ed\u30fc\u30c9\uff1a\u30b2\u30fc\u30e0\u672c\u7de8\u306e\u30bb\u30fc\u30d6\u6a5f\u80fd\u3068\u306f\u5225\u306b\u3001\u4efb\u610f\u306e\u30bf\u30a4\u30df\u30f3\u30b0\u3067\u30bb\u30fc\u30d6/\u30ed\u30fc\u30c9\u304c\u53ef\u80fd\u306b\u306a\u308a\u307e\u3059\u3002\n\u30dc\u30fc\u30ca\u30b9\u30d1\u30c3\u30af\uff1a\u5bfe\u6226\u7d42\u4e86\u6642\u306b\u3082\u3089\u3048\u308b\u5831\u916c\u30ab\u30fc\u30c9\u306e\u91cf\u3092\u5897\u52a0\u3055\u305b\u307e\u3059\u3002\u30aa\u30d7\u30b7\u30e7\u30f3\u9805\u76ee\u3067ON/OFF\u304c\u53ef\u80fd\u3067\u3059\u3002\n\u624b\u672d\u8868\u793a\uff1a\u539f\u4f5c\u3067\u306f\u7279\u5b9a\u306e\u30bf\u30a4\u30df\u30f3\u30b0\u3067\u306e\u307f\u78ba\u8a8d\u3059\u308b\u