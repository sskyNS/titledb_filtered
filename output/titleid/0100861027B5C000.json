	"intro": "\u30af\u30e9\u30b7\u30c3\u30af\u3092\u697d\u3057\u304f\u5b66\u3076\u30af\u30a4\u30ba",
	"description": "\u3042\u306a\u305f\u306f\u30af\u30e9\u30b7\u30c3\u30af\u306e\u540d\u66f2\u3092\u8aac\u660e\u3067\u304d\u307e\u3059\u304b\uff1f\n\n\u300c\u3069\u3053\u304b\u3067\u805e\u3044\u305f\u3053\u3068\u304c\u3042\u308b\u300d\n\u300c\u6709\u540d\u306a\u66f2\u306a\u306e\u306f\u77e5\u3063\u3066\u3044\u308b\u300d\n\u305d\u3093\u306a\u30af\u30e9\u30b7\u30c3\u30af\u97f3\u697d\u3082\u3001\u5b9f\u306f\u4f5c\u66f2\u5bb6\u3084\u80cc\u666f\u3001\n\u66f2\u306e\u7279\u5fb4\u3092\u3042\u307e\u308a\u77e5\u3089\u306a\u3044\u3053\u3068\u304c\u3042\u308b\u304b\u3082\u3057\u308c\u307e\u305b\u3093\u3002\n\n\u672c\u4f5c\u306f\u3001\u30af\u30e9\u30b7\u30c3\u30af\u97f3\u697d\u3092\u30c6\u30fc\u30de\u306b\u3057\u305f\n\u97f3\u697d\u6559\u990a\u30c1\u30a7\u30c3\u30af\u30af\u30a4\u30ba\u3067\u3059\u3002\n\n\u6709\u540d\u306a\u4f5c\u66f2\u5bb6\u3001\u540d\u66f2\u306e\u30a8\u30d4\u30bd\u30fc\u30c9\u3001\u697d\u5668\u3084\u97f3\u697d\u306e\u77e5\u8b58\u3002\n\u30af\u30e9\u30b7\u30c3\u30af\u306e\u4e16\u754c\u3092\u3082\u3068\u306b\u3001\n\u77e5\u3063\u3066\u3044\u308b\u3088\u3046\u3067\u77e5\u3089\u306a\u3044\u540d\u66f2\u3084\u97f3\u697d\u306e\u77e5\u8b58\u3092\u30af\u30a4\u30ba\u5f62\u5f0f\u3067\u51fa\u984c\u3057\u307e\u3059\u3002\n\n\u904a\u3073\u65b9\u306f\u304b\u3093\u305f\u3093\u3002\n\u30fb\u554f\u984c\u3092\u8aad\u3093\u3067\n\u30fb\u76f4\u611f\u3067\u7b54\u3048\u3092\u9078\u3076\u3060\u3051\n\u30fb\u7d50\u679c\u3068\u89e3\u8aac\u3067\u3001\u305d\u306e\u5834\u3067\u7406\u89e3\n\n\u6b63\u89e3\u3057\u3066\u3082\u6cb9\u65ad\u3067\u304d\u306a\u3044\u3001\n\u9593\u9055\u3048\u3066\u3082\u300c\u306a\u308b\u307b\u3069\u300d\u3068\u5b66\u3079\u308b\u554f\u984c\u3070\u304b\u308a\u3002\n\n1\u554f\u304b\u3089\u6c17\u8efd\u306b\u904a\u3079\u3066\u3001\n\u6687\u3064\u3076\u3057\u306b\u3082\u3001\u97f3\u697d\u6559\u990a\u306e\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u306b\u3082\u3074\u3063\u305f\u308a\u3002\n\n\u3042\u306a\u305f\u306e\u30af\u30e9\u30b7\u30c3\u30af\u77e5\u8b58\u3001\u3069\u3053\u307e\u3067\u901a\u7528\u3059\u308b\u304b\u8a66\u3057\u3066\u307f\u307e\u305b\u3093\u304b\uff1f\n\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\nTT\u3067\u306f\u52d5\u753b\u914d\u4fe1\u8005\u69d8\u306e\u30b2\u30fc\u30e0\u5b9f\u6cc1\u3092\u5fdc\u63f4\u3057\u3066\u304a\u308a\u307e\u3059\u3002\n\u500b\u4eba\u30fb\u6cd5\u4eba\u3092\u554f\u308f\u305a\u3001\u30b2\u30fc\u30e0\u5b9f\u6cc1\u306b\u3064\u3044\u3066TT\u306b\u8a31\u53ef\u3092\u53d6\u308b\u5fc5\u8981\u306f\u3042\u308a\u307e\u305b\u3093\u3002",
