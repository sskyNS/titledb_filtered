	"intro": "\u9b54\u6cd5\u3001\u304d\u3089\u3081\u304d\u3001\u305d\u3057\u3066\u4eca\u307e\u3067\u898b\u305f\u4e2d\u3067\u4e00\u756a\u304b\u308f\u3044\u3044\u5973\u306e\u5b50\u305f\u3061\u3002\n\u30d7\u30ec\u30a4\u3057\u3066\u3001\u30b9\u30b3\u30a2\u3092\u4e0a\u3052\u3066\u3001\u5168\u54e1\u30a2\u30f3\u30ed\u30c3\u30af\u3057\u3088\u3046\u3002",
	"description": "\u9b54\u6cd5\u304c\u73fe\u5b9f\u306b\u5b58\u5728\u3059\u308b\u4e16\u754c\u3078\u3088\u3046\u3053\u305d\u3002\u5973\u306e\u5b50\u305f\u3061\u306f\u3082\u3046\u3001\u62b5\u6297\u3067\u304d\u306a\u3044\u304f\u3089\u3044\u304b\u308f\u3044\u3044\u3002\u30d1\u30b9\u30c6\u30eb\u30ab\u30e9\u30fc\u306e\u7a7a\u3001\u8f1d\u304f\u661f\u3005\u3001\u305d\u3057\u3066\u9b45\u529b\u3068\u540c\u3058\u304f\u3089\u3044\u5f37\u3044\u529b\u3092\u6301\u3064\u304b\u308f\u3044\u3044\u30a2\u30cb\u30e1\u306e\u5973\u306e\u5b50\u305f\u3061\u3002\u3053\u3053\u306f\u3042\u306a\u305f\u304c\u8a2a\u308c\u305f\u4e2d\u3067\u4e00\u756a\u304b\u308f\u3044\u3044\u5834\u6240\u3067\u3059\u3002\n\n\u30df\u30cb\u30b2\u30fc\u30e0\u3092\u30d7\u30ec\u30a4\u3057\u3066\u3001\u30b9\u30b3\u30a2\u3067\u30ae\u30e3\u30e9\u30ea\u30fc\u3092\u5c11\u3057\u305a\u3064\u958b\u3044\u3066\u3044\u3053\u3046\u3002\u4e0a\u306b\u884c\u3051\u3070\u884c\u304f\u307b\u3069\u3001\u5f7c\u5973\u305f\u3061\u306f\u59ff\u3092\u898b\u305b\u3066\u304f\u308c\u308b\u3002\n\n\u5143\u6c17\u3044\u3063\u3071\u3044\u306e\u9b54\u6cd5\u5c11\u5973\u304b\u3089\u3001\u30df\u30b9\u30c6\u30ea\u30a2\u30b9\u3067\u9b45\u60d1\u7684\u306a\u9b54\u6cd5\u5c11\u5973\u307e\u3067\u3001\u305d\u308c\u305e\u308c\u500b\u6027\u304c\u3042\u3063\u3066\u3001\u30b2\u30fc\u30e0\u4e2d\u306e\u5fdc\u63f4\u306e\u4ed5\u65b9\u3082\u307f\u3093\u306a\u9055\u3046\u3002\n\n\u3042\u306a\u305f\u304c\u52dd\u3063\u3066\u3044\u308b\u3068\u304d\u3001\u3061\u3083\u3093\u3068\u6c17\u3065\u3044\u3066\u304f\u308c\u307e\u3059\u3002\n\n\u5168\u54e1\u30a2\u30f3\u30ed\u30c3\u30af\u3059\u308b\u81ea\u4fe1\u306f\u3042\u308b\uff1f\n\n\n\u7279\u5fb4\uff1a\n\n\u25cf \u3069\u306e\u30e2\u30fc\u30c9\u306b\u3082\u3001\u7d9a\u3051\u308b\u7406\u7531\u304c\u3042\u308b\uff1a\u982d\u3092\u4f7f\u3063\u3066\u3001\u53cd\u5c04\u795e\u7d4c\u3092\u8a66\u3057\u3066\u3001\u30b9\u30b3\u30a2\u3092\u4f38\u3070\u305d\u3046\u3002\u305d\u306e1\u70b91\u70b9\u304c\u3001\u6b21\u306e\u30a2\u30f3\u30ed\u30c3\u30af\u30