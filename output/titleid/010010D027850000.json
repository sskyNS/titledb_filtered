	"intro": "\ucc28\ub7c9\uc5d0 \uc5f0\ub8cc\ub97c \uacf5\uae09\ud558\uace0, \uc0c1\uc810\uc744 \uc6b4\uc601\ud558\uba70, \ub3c4\ub85c\ubcc0 \uc81c\uad6d\uc744 \uc131\uc7a5\uc2dc\ud0a4\uc138\uc694.",
	"description": "\uc8fc\uc720\uc18c \ub9e4\ub2c8\uc800\uac00 \ub418\uc5b4 \ubc84\ub824\uc9c4 \ub3c4\ub85c\ubcc0 \uc8fc\uc720\uc18c\ub97c \uc778\uc218\ud558\uc138\uc694. \ub179\uc2a8 \ud38c\ud504\uc640 \ud145 \ube48 \uc9c4\uc5f4\ub300\uc5d0\uc11c \ud65c\uae30\ucc2c \uc911\uc2ec\uc9c0\ub85c \uc131\uc7a5\uc2dc\ud0a4\ub294 \ubaa8\ub4e0 \uacb0\uc815\uc740 \ub2f9\uc2e0\uc5d0\uac8c \ub2ec\ub824 \uc788\uc2b5\ub2c8\ub2e4. \ucc28\ub7c9\uc5d0 \uc5f0\ub8cc\ub97c \uacf5\uae09\ud558\uace0, \uc138\ucc28\ub97c \ud558\uace0, \uc0c1\uc810\uc744 \uad00\ub9ac\ud558\uba70, \uc2dc\uc124\uc744 \uc720\uc9c0\ud558\uc138\uc694 \u2014 \uc131\uacf5\uc740 \ub2f9\uc2e0\uc758 \uae30\uc220, \uc18d\ub3c4, \uc804\ub7b5\uc5d0 \ub2ec\ub824 \uc788\uc2b5\ub2c8\ub2e4. \ubaa8\ub4e0 \uc5ed\ud560\uc774 \uc911\uc694\ud558\uace0 \ubaa8\ub4e0 \uace0\uac1d\uc774 \uc18c\uc911\ud55c \ud480\uc11c\ube44\uc2a4 \uc8fc\uc720\uc18c \uc6b4\uc601\uc758 \ub3c4\uc804\uc744 \uacbd\ud5d8\ud574 \ubcf4\uc138\uc694.\n\n\uc8fc\uc694 \ud2b9\uc9d5:\n\u2022 \uc8fc\uc720 \ubc0f \uc11c\ube44\uc2a4: \uc5f0\ub8cc\ub97c \uc548\uc815\uc801\uc73c\ub85c \uacf5\uae09\ud558\uace0 \uace0\uac1d \ub9cc\uc871\ub3c4\ub97c \uc720\uc9c0\ud558\uc138\uc694.\n\u2022 \ub9e4\uc7a5 \uad00\ub9ac: \uc9c4\uc5f4\ub300\ub97c \ucc44\uc6b0\uace0 \uc0c1\ud488\uc744 \ud310\ub9e4\ud558\uba70 \ub354 \ub9ce\uc740 \ubc29\ubb38\uac1d\uc744 \uc720\uce58\ud558\uc138\uc694.\n\u2022 \uc138\ucc28 \ubc0f \uc720\uc9c0\ubcf4\uc218: \ucc28\ub7c9\uc744 \uccad\uc18c\ud558\uace0 \uc190\uc0c1\ub41c \uc7a5\ube44\ub97c \uc218\ub9ac\ud558\uc138\uc694.\n\u2022 \uacf5\uae09 \ubc0f \uc5c5\uadf8\ub808\uc774\ub4dc: \ubc30\uc1a1\uc744 \uad00\ub9ac\ud558\uace0 \uc7ac\uace0\ub97c \ud655\uc778\ud558\uba70 \uc8fc\uc720\uc18c\ub97c \uac1c\uc120\ud558\uc138\uc694.\n\u2022 \ub2e4\uc591\ud55c \uc5ed\ud560: \uacc4\uc0b0\uc6d0, \uc815\ube44\uc0ac, \uccad\uc18c \uc9c1\uc6d0\uc73c\ub85c \ud50c\ub808\uc774\ud558\uac70\ub098 \ub9e4\ub2c8\uc800\ub85c \uc804\uccb4\ub97c \uad00\ub9ac\ud558\uc138\uc694.\n\n\uc78a\ud600\uc9c4 \uc815\ucc28 \uc9c0\uc810\uc744 \ubc88\ucc3d\ud558\ub294 \ub3c4\ub85c\ubcc0 \uc81c\uad6d\uc73c\ub85c \ud0c8\ubc14\uafc8\uc2dc\ud0a4\uc138\uc694. Gas Station Simulator\ub294 \ub2e8\uc21c\ud55c \uac8c\uc784\uc774 \uc544\ub2d9\ub2c8\ub2e4 \u2014 \ubaa8\ub4e0 \ub514\ud14c\uc77c\uc744 \ub9c8\uc2a4\ud130\ud558\uace0 \uc0ac\uc5c5\uc744 \uc131\uc7a5\uc2dc\ud0a4\uba70 \ucd5c\uace0\uc758 \uc8fc\uc720\uc18c \uacbd\ud5d8\uc744 \ub9cc\ub4e4\uc5b4\uac08 \uae30\ud68c\uc785\ub2c8\ub2e4. \uc6b4\uc804\ub300\ub97c \uc7a1\uc744 \uc900\ube44\uac00 \ub418\uc168\ub098\uc694?",
