	"intro": "\u65b0\u30b8\u30e3\u30f3\u30eb\u300c\u30e1\u30f3\u30bf\u30eb\u30ed\u30fc\u30c6\u30fc\u30b7\u30e7\u30f3\u8ff7\u8def\u300d\n\u5c55\u958b\u56f3\u304b\u3089\u7acb\u4f53\u8ff7\u8def\u3092\u30a4\u30e1\u30fc\u30b8\u3059\u308b\u3001\u3072\u3089\u3081\u304d\u8133\u30c8\u30ec\u30b2\u30fc\u30e0\n\u3042\u306a\u305f\u306e\u8133\u306f\u3053\u306e\u8ca0\u8377\u306b\u8010\u3048\u3089\u308c\u307e\u3059\u304b\uff1f",
	"description": "\u3042\u306a\u305f\u306e\u80fd\u529b\u306f\u3001\n\u3000\u7bb1\u306e\u8868\u9762\u3092\u8ee2\u304c\u308b\u30dc\u30fc\u30eb\u3092\u64cd\u308b\u80fd\u529b\u3068\u3001\n\u3000\u8907\u96d1\u306a\u5c55\u958b\u56f3\u3092\u8aad\u307f\u89e3\u304f\u80fd\u529b\u3067\u3059\u3002\n\u77e5\u80fd\u3092\u99c6\u4f7f\u3057\u3001\u7acb\u4f53\u306e\u8868\u9762\u4e0a\u306b\u63cf\u304b\u308c\u305f\u8ff7\u8def\u3092\u89e3\u3044\u3066\u30cf\u30b3\u306b\u5c01\u5370\u3055\u308c\u305f3DCG\u3092\u5fa9\u6d3b\u3055\u305b\u3066\u3002\n\n\u3010\u30b2\u30fc\u30e0\u6982\u8981\u3011\n\u53e4\u4ee3\u6587\u660e\u304c\u6b8b\u3057\u305f\u3068\u601d\u308f\u308c\u308b\u30b5\u30a4\u30d0\u30fc\u7a7a\u9593\n\u4e2d\u306b\u306f\u7bb1\u306b\u9589\u3058\u8fbc\u3081\u3089\u308c\u305f3D\u30aa\u30d6\u30b8\u30a7\u30af\u30c8\n\n\u4e00\u898b\u3059\u308b\u3068\u5358\u7d14\u306a\u7acb\u65b9\u4f53\u3002\u3057\u304b\u3057\u305d\u306e\u8868\u9762\u306b\u306f\u3001\u9ad8\u5ea6\u306a\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u3068\u3057\u3066\u5f35\u308a\u5de1\u3089\u3055\u308c\u305f\u300c\u7acb\u4f53\u8ff7\u8def\u300d\u304c\u523b\u307e\u308c\u3066\u3044\u307e\u3059\u3002\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u8ff7\u8def\u306e\u4e0a\u3092\u8ee2\u304c\u308b\u30dc\u30fc\u30eb\u3092\u81ea\u5728\u306b\u52d5\u304b\u3057\u3001\u30b4\u30fc\u30eb\u3078\u3068\u5c0e\u304f\u3053\u3068\u3067\u3001\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u3092\u89e3\u9664\u3057\u3066\u3044\u304d\u5185\u90e8\u306b\u7720\u308b\u672a\u77e5\u306e\u30aa\u30d6\u30b8\u30a7\u30af\u30c8\u3092\u89e3\u653e\u3057\u3066\u3044\u304d\u307e\u3059\u3002\n\n\u3010\u4e3b\u306a\u7279\u5fb4\u3011\n\u300c\u5c55\u958b\u56f3\u300d\u3092\u8aad\u307f\u89e3\u304f\u8ad6\u7406\u30d1\u30ba\u30eb\uff1a 2\u6b21\u5143\u306e\u300c\u5c55\u958b\u56f3\u300d\u30923\u6b21\u5143\u69cb\u9020\u3068\u3057\u3066\u77ac\u6642\u306b\u628a\u63e1\u3059\u308b\u3001\u3042\u306a\u305f\u306e\u7a7a\u9593\u8a8d\u8b58\u80fd\u529b\u304c\u8a66\u3055\u308c\u307e\u3059\u3002",
